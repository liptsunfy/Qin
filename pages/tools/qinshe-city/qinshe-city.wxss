.page { padding: 24rpx; background:#f7f8fa; min-height:100vh; }
.card { background:#fff; border-radius:20rpx; padding:24rpx; margin-bottom:20rpx; }
.title { display:block; font-size:36rpx; font-weight:600; color:#222; margin-bottom:10rpx; }
.desc { display:block; font-size:26rpx; color:#666; }
.item { display:flex; align-items:center; justify-content:space-between; padding:18rpx 0; border-bottom:1rpx solid #f1f1f1; }
.item:last-child { border-bottom:none; }
.name { font-size:29rpx; color:#222; }
.arrow { font-size:34rpx; color:#bbb; }

.city-count { display:block; margin-top:6rpx; font-size:23rpx; color:#888; line-height:1.5; }
