<view class="page">
  <view class="card hero">
    <text class="title">{{province}}</text>
  </view>

  <view class="card">
    <view wx:for="{{cities}}" wx:key="city" class="item" bindtap="onCityTap" data-city="{{item.city}}">
      <view>
        <text class="name">{{item.city}}</text>
        <text class="districts" wx:if="{{item.districts && item.districts.length}}">区县：{{item.districts.join("、")}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
