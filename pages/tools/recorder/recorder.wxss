 .page {
  padding: 24rpx 24rpx 80rpx;
  background: linear-gradient(180deg,#f6f7fb 0%,#f4f5f8 100%);
  min-height: 100vh;
  box-sizing: border-box;
  display:flex;
  flex-direction:column;
}

.header {
  margin-bottom: 24rpx;
}

 .card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(18,23,40,0.08);
  border: none;
  margin-bottom: 24rpx;
}

 .mode-card {
  border: 1rpx solid rgba(125, 103, 70, 0.12);
  background: #fff;
}

.mode-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.mode-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1f25;
}

 .mode-tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(74,90,168,.12);
  color: #4a5aa8;
}

.mode-desc {
  font-size: 22rpx;
  color: #5c6475;
  margin-bottom: 12rpx;
}

.mode-tips {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  font-size: 22rpx;
  color: #7b8394;
}

.tip-item {
  line-height: 1.6;
}

.record-card {
  text-align: center;
}

 .timer {
  font-size: 64rpx;
  font-weight: 700;
  color: #4a5aa8;
}

.status {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7b8394;
}

.actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.secondary-btn,
.primary-btn {
  min-width: 180rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

 .secondary-btn {
  background: #eef2ff;
  color: #1d1f25;
}

 .secondary-btn.pause {
  background: #eef2ff;
  color: #4a5aa8;
}

 .primary-btn {
  background: #1d1f25;
  color: #ffffff;
}

.list-card .section-title {
  font-size: 26rpx;
  color: #4b4b4b;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

 .section-hint {
  font-size: 20rpx;
  color: #4a5aa8;
  background: #eef2ff;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.empty {
  font-size: 24rpx;
  color: #a0a0a0;
  text-align: center;
  padding: 24rpx 0;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: 0;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1d1f25;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  font-size: 22rpx;
  color: #7b8394;
}

.record-arrow {
  font-size: 36rpx;
  color: #9aa2b1;
}

.page-title-card{padding:20rpx 24rpx;margin-bottom:24rpx}
.page-title-wrap{display:flex;flex-direction:column;gap:8rpx;min-width:0}
.page-title{font-size:36rpx;line-height:1.3;font-weight:600;color:#222;word-break:break-all}
.page-subtitle{font-size:22rpx;line-height:1.6;color:#7b8394}
.footer-copy{padding:12rpx 0 20rpx;text-align:center;font-size:22rpx;color:#9a8d7e}
