.page {
  padding: 32rpx 24rpx 80rpx;
  background: #f6f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7a7a7a;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(92, 108, 255, 0.08);
  margin-bottom: 24rpx;
}

.record-card {
  text-align: center;
}

.record-hero {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: center;
}

.timer {
  font-size: 64rpx;
  font-weight: 700;
  color: #5c6cff;
}

.status-text {
  font-size: 24rpx;
  color: #8a8a8a;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #f4f5f8;
}

.status-text.recording {
  color: #ff6b6b;
  background: #ffecec;
}

.status-text.paused {
  color: #ff9f1c;
  background: #fff4e5;
}

.actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.secondary-btn,
.primary-btn {
  min-width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.secondary-btn {
  background: #f1f3ff;
  color: #5c6cff;
}

.secondary-btn.pause {
  background: #fff4e5;
  color: #ff9f1c;
}

.primary-btn {
  background: linear-gradient(135deg, #5c6cff, #7b7bff);
  color: #ffffff;
}

.primary-btn.danger {
  background: linear-gradient(135deg, #ff7b7b, #ff5656);
}

.record-hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9a9a9a;
}

.list-card .section-title {
  font-size: 26rpx;
  color: #4b4b4b;
  margin-bottom: 16rpx;
}

.empty {
  font-size: 24rpx;
  color: #a0a0a0;
  text-align: center;
  padding: 24rpx 0;
}

.record-item {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: 0;
}

.record-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.record-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2a2a2a;
}

.record-meta {
  font-size: 22rpx;
  color: #8a8a8a;
}

.record-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.play-btn {
  padding: 10rpx 22rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #5c6cff, #7b7bff);
}

.chip-btn {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #5c6cff;
  background: #f1f3ff;
}

.chip-btn.danger {
  color: #ff6b6b;
  background: #ffecec;
}
