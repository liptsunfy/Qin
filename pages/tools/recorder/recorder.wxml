<view class="page">
  <view class="header">
    <text class="title">练习录音</text>
    <text class="subtitle">保存每次练习的声音，随时回听</text>
  </view>

  <view class="card record-card">
    <view class="timer">{{durationText}}</view>
    <view class="status">
      <text wx:if="{{!isRecording}}">准备就绪</text>
      <text wx:elif="{{isPaused}}">已暂停</text>
      <text wx:else>录音中...</text>
    </view>

    <view class="actions">
      <button class="secondary-btn" bindtap="startRecording" wx:if="{{!isRecording}}">开始录音</button>
      <button class="secondary-btn pause" bindtap="pauseRecording" wx:if="{{isRecording && !isPaused}}">暂停</button>
      <button class="secondary-btn" bindtap="resumeRecording" wx:if="{{isRecording && isPaused}}">继续</button>
      <button class="primary-btn" bindtap="stopRecording" wx:if="{{isRecording}}">保存</button>
    </view>
  </view>

  <view class="card list-card">
    <view class="section-title">我的录音</view>
    <view wx:if="{{recordings.length === 0}}" class="empty">还没有录音，快来记录第一段声音吧～</view>

    <view wx:for="{{recordings}}" wx:key="id" class="record-item">
      <view class="record-info">
        <text class="record-name">{{item.name}}</text>
        <text class="record-meta">{{item.durationText}}</text>
      </view>
      <view class="record-actions">
        <button class="icon-btn" data-record="{{item}}" bindtap="togglePlay">
          {{playingId === item.id ? '停止' : '播放'}}
        </button>
        <button class="icon-btn" data-record="{{item}}" bindtap="shareRecording">分享</button>
        <button class="icon-btn danger" data-record="{{item}}" bindtap="deleteRecording">删除</button>
      </view>
    </view>
  </view>
</view>
