.page{padding:16rpx;background:linear-gradient(180deg,#f6f7fb 0%,#f4f5f8 100%);min-height:100vh;box-sizing:border-box}
.card{background:#fff;border-radius:24rpx;padding:20rpx;margin-bottom:12rpx;box-shadow:0 10rpx 24rpx rgba(18,23,40,.08)}
.hero-card{background:linear-gradient(135deg,#1d1f25 0%,#3b3f55 100%)}
.title{display:block;font-size:36rpx;font-weight:600;color:#fff}
.subtitle{display:block;margin-top:8rpx;font-size:24rpx;color:rgba(255,255,255,.75)}
.content-card{display:flex;flex-direction:column;gap:16rpx}
.content-text{font-size:26rpx;line-height:1.8;color:#2d2f36}
.content-status{font-size:24rpx;color:#7b8394}
