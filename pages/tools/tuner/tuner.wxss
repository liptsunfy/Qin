.tuner-page{padding:16rpx;background:linear-gradient(180deg,#f6f7fb 0%,#f4f5f8 100%);min-height:100vh;box-sizing:border-box}
.card{background:#fff;border-radius:24rpx;padding:18rpx;margin-bottom:12rpx;box-shadow:0 10rpx 24rpx rgba(18,23,40,0.08)}
.hero{background:linear-gradient(135deg,#1d1f25 0%,#3b3f55 100%);color:#fff;box-shadow:none}
.hero-title{font-size:36rpx;font-weight:600;color:#fff;letter-spacing:1rpx}
.settings-card{display:flex;flex-direction:column;gap:10rpx}
.setting-row{display:flex;justify-content:space-between;align-items:center;gap:14rpx;flex-wrap:wrap}
.setting-row.compact{align-items:flex-start}
.setting-label{font-size:24rpx;color:#2d2f36;font-weight:600}
.setting-value{display:flex;flex-direction:column;align-items:flex-end;gap:6rpx;text-align:right}
.setting-value.picker{width:60%}
.picker-content{display:flex;flex-direction:column;align-items:flex-end;gap:6rpx}
.setting-desc{font-size:20rpx;color:#8c93a5}
.setting-input{flex:1;display:flex;align-items:center;justify-content:flex-end;gap:10rpx}
.setting-fixed-value{font-size:24rpx;color:#2d2f36;font-weight:700;background:#f3f5fa;padding:10rpx 18rpx;border-radius:14rpx}
.a4-stepper{display:flex;align-items:center;gap:10rpx;background:#f3f5fa;border-radius:18rpx;padding:6rpx 10rpx;width:fit-content}
.step-btn{width:56rpx;height:56rpx;border-radius:16rpx;background:#ffffff;color:#2d2f36;font-weight:700;font-size:28rpx;line-height:56rpx;text-align:center;box-shadow:0 6rpx 12rpx rgba(0,0,0,0.06)}
.a4-input{width:120rpx;height:56rpx;border-radius:14rpx;background:#ffffff;text-align:center;font-size:26rpx;color:#2d2f36;font-weight:700;box-shadow:inset 0 0 0 1rpx rgba(0,0,0,0.04)}
.setting-value-text{font-size:20rpx;color:#8a92a3;min-width:32rpx;text-align:right;font-weight:600}
.status-card{display:flex;flex-direction:column;gap:12rpx}
.status-header{display:flex;justify-content:space-between;align-items:center}
.status-main{display:flex;align-items:baseline;gap:12rpx}
.status-string{font-size:34rpx;font-weight:600;color:#222}
.status-note{font-size:26rpx;color:#c18b5d;font-weight:600}
.status-actions{display:flex;align-items:center;gap:10rpx;font-size:22rpx;color:#5c6475;background:#f6f7fb;padding:6rpx 12rpx;border-radius:999rpx}
.status-toggle{font-size:22rpx;color:#5c6475}
.status-meta{display:flex;justify-content:space-between;font-size:22rpx;color:#7b8394}
.dial-wrap{display:flex;flex-direction:column;gap:10rpx;align-items:center;padding:8rpx 8rpx 0}
.dial-label-row{width:100%;display:flex;justify-content:space-between;padding:0 12rpx}
.dial-caption{font-size:20rpx;font-weight:600}
.dial-caption.low{color:#6480a5}
.dial-caption.center{color:#6f7788}
.dial-caption.high{color:#b26a6a}
.dial-scale-text{width:100%;display:flex;justify-content:space-between;font-size:20rpx;color:#9aa2b1;padding:0 10rpx}
.status-pill{padding:10rpx 18rpx;border-radius:999rpx;font-size:22rpx;display:inline-flex;align-items:center;justify-content:center;background:#f2f2f2;color:#666;font-weight:600}
.status-pill.ok{background:#ecf8f2;color:#2b7a5a}
.status-pill.low{background:#fef3e6;color:#b26a00}
.status-pill.high{background:#ffecec;color:#b54646}
.status-pill.listening{background:#f2f6ff;color:#4a5aa8}
.status-buttons{display:flex;gap:10rpx;flex-wrap:wrap}
.status-buttons button{flex:1;border-radius:22rpx;font-size:24rpx;padding:12rpx 0;font-weight:600}
.status-buttons .primary{background:#1d1f25;color:#fff}
.status-buttons .ghost{background:#f2f4f8;color:#1d1f25}
.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx}
.section-title{font-size:30rpx;font-weight:600;color:#222}
.section-action{font-size:22rpx;color:#8d94a4}
.compact-card{padding:18rpx}
.string-grid{display:grid;grid-template-columns:repeat(3, 1fr);gap:10rpx}
.string-item{padding:14rpx;border-radius:16rpx;background:#f7f8fb;display:flex;flex-direction:column;gap:8rpx;border:1rpx solid transparent;transition:all 0.2s ease}
.string-item.active{border-color:#1d1f25;background:#fff;box-shadow:0 6rpx 18rpx rgba(29,31,37,0.08)}
.string-name{font-size:24rpx;font-weight:600;color:#222}
.string-note{font-size:22rpx;color:#8b6a45;font-weight:600}
.string-frequency{font-size:20rpx;color:#667085}
.string-status{font-size:18rpx;color:#8b93a3;padding:4rpx 10rpx;border-radius:999rpx;background:#eef2f7;align-self:flex-start}
.string-status.tuned{color:#2b7a5a;font-weight:600}

.bar-wrap{position:relative;width:100%;height:44rpx;border-radius:999rpx;overflow:hidden;display:flex;box-shadow:inset 0 2rpx 10rpx rgba(0,0,0,.08)}
.bar-zone{height:100%}
.bar-zone.low{flex:1;background:linear-gradient(90deg,#dbe9ff 0%,#e7f0ff 100%)}
.bar-zone.center{flex:.8;background:#eef2f8}
.bar-zone.high{flex:1;background:linear-gradient(90deg,#fff0ee 0%,#ffe0de 100%)}
.bar-center-line{position:absolute;left:50%;top:0;bottom:0;width:4rpx;transform:translateX(-50%);background:#2f3645;opacity:.7}
.bar-pointer{position:absolute;top:50%;width:20rpx;height:20rpx;border-radius:50%;background:#1d1f25;border:4rpx solid #fff;box-shadow:0 4rpx 10rpx rgba(0,0,0,.24);transform:translate(-50%,-50%);transition:left .12s linear}
.dial-wrap{display:flex;flex-direction:column;gap:12rpx;align-items:center;padding:8rpx 8rpx 0;width:100%}

/* 兼容旧模板缓存：强制隐藏历史 dial 文案节点（0c/目标） */
.dial-value,.dial-target{display:none!important}

.string-top-row{display:flex;align-items:center;justify-content:space-between;gap:8rpx}
.string-meta-row{display:flex;flex-direction:column;gap:4rpx}
.string-item.compact{padding:12rpx;min-height:116rpx;justify-content:center}
.string-item.compact .string-status{font-size:16rpx;line-height:1.2;white-space:nowrap}
.string-item.compact .string-name{font-size:22rpx}
@media (max-width: 360px){.string-grid{grid-template-columns:repeat(2,1fr)}}
