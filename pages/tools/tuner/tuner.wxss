.tuner-page{padding:20rpx;background:linear-gradient(180deg,#f6f7fb 0%,#f4f5f8 100%);min-height:100vh;box-sizing:border-box}
.card{background:#fff;border-radius:28rpx;padding:24rpx;margin-bottom:18rpx;box-shadow:0 12rpx 30rpx rgba(18,23,40,0.08)}
.hero{background:linear-gradient(135deg,#1d1f25 0%,#3b3f55 100%);color:#fff;box-shadow:none}
.hero-title{font-size:38rpx;font-weight:600;color:#fff;letter-spacing:1rpx}
.hero-subtitle{margin-top:10rpx;font-size:24rpx;color:rgba(255,255,255,0.7)}
.settings-card{display:flex;flex-direction:column;gap:16rpx}
.setting-row{display:flex;justify-content:space-between;align-items:center;gap:16rpx}
.setting-label{font-size:24rpx;color:#2d2f36;font-weight:600}
.setting-value{display:flex;flex-direction:column;align-items:flex-end;gap:6rpx;text-align:right}
.setting-desc{font-size:20rpx;color:#8c93a5}
.setting-slider{flex:1;display:flex;align-items:center;gap:12rpx}
.setting-value-text{font-size:22rpx;color:#5b6270;min-width:100rpx;text-align:right;font-weight:600}
.setting-hint{font-size:22rpx;color:#7c859a;padding:12rpx 16rpx;border-radius:16rpx;background:#f3f5fa}
.status-card{display:flex;flex-direction:column;gap:18rpx}
.status-header{display:flex;justify-content:space-between;align-items:center}
.status-main{display:flex;align-items:baseline;gap:12rpx}
.status-string{font-size:34rpx;font-weight:600;color:#222}
.status-note{font-size:26rpx;color:#c18b5d;font-weight:600}
.status-actions{display:flex;align-items:center;gap:10rpx;font-size:22rpx;color:#5c6475;background:#f6f7fb;padding:6rpx 12rpx;border-radius:999rpx}
.status-toggle{font-size:22rpx;color:#5c6475}
.status-meta{display:flex;justify-content:space-between;font-size:22rpx;color:#7b8394;gap:12rpx}
.status-target{font-size:22rpx;color:#7b8394}
.meter{display:flex;flex-direction:column;gap:10rpx}
.meter-track{height:24rpx;background:#eef1f6;border-radius:999rpx;position:relative;overflow:hidden}
.meter-center{position:absolute;left:50%;top:0;width:4rpx;height:100%;background:#1d1f25}
.meter-fill{position:absolute;left:50%;top:0;width:20rpx;height:100%;border-radius:999rpx;background:linear-gradient(180deg,#d6a168,#b67c46);transition:transform 0.3s ease}
.meter-labels{display:flex;justify-content:space-between;font-size:20rpx;color:#a0a7b6}
.status-pill{padding:10rpx 18rpx;border-radius:999rpx;font-size:22rpx;display:inline-flex;align-items:center;justify-content:center;background:#f2f2f2;color:#666;font-weight:600}
.status-pill.ok{background:#ecf8f2;color:#2b7a5a}
.status-pill.low{background:#fef3e6;color:#b26a00}
.status-pill.high{background:#ffecec;color:#b54646}
.status-pill.listening{background:#f2f6ff;color:#4a5aa8}
.status-buttons{display:flex;gap:12rpx}
.status-buttons button{flex:1;border-radius:22rpx;font-size:24rpx;padding:12rpx 0;font-weight:600}
.status-buttons .primary{background:#1d1f25;color:#fff}
.status-buttons .ghost{background:#f2f4f8;color:#1d1f25}
.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx}
.section-title{font-size:30rpx;font-weight:600;color:#222}
.section-action{font-size:22rpx;color:#8d94a4}
.string-grid{display:grid;grid-template-columns:repeat(2, 1fr);gap:12rpx}
.string-item{padding:18rpx;border-radius:18rpx;background:#f7f8fb;display:flex;flex-direction:column;gap:6rpx;border:1rpx solid transparent;transition:all 0.2s ease}
.string-item.active{border-color:#1d1f25;background:#fff;box-shadow:0 6rpx 18rpx rgba(29,31,37,0.08)}
.string-name{font-size:24rpx;font-weight:600;color:#222}
.string-note{font-size:22rpx;color:#c18b5d}
.string-status{font-size:20rpx;color:#9aa2b1}
.string-status.tuned{color:#2b7a5a;font-weight:600}
.tips .tip-item{display:flex;gap:10rpx;margin-top:10rpx}
.tips .tip-dot{color:#b18a5a}
.tips .tip-text{font-size:22rpx;color:#6b7280;line-height:1.6}
