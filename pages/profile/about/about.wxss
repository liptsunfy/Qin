.page{min-height:100vh;background:#f5f3ef;padding:24rpx 24rpx 80rpx;box-sizing:border-box}
.card{background:#fffdf9;border-radius:24rpx;padding:28rpx;margin-bottom:24rpx;border:1rpx solid rgba(125,103,70,.08);box-shadow:0 10rpx 26rpx rgba(74,58,36,.05)}
.hero{background:linear-gradient(180deg,#fffdf9 0%,#f6f0e8 100%)}
.hero-top{display:flex;justify-content:space-between;align-items:flex-start;gap:20rpx}
.eyebrow{display:block;font-size:20rpx;letter-spacing:3rpx;color:#9a8d7e;margin-bottom:8rpx}
.title{display:block;font-size:40rpx;font-weight:700;color:#2d2418}
.subtitle{display:block;margin-top:10rpx;font-size:24rpx;line-height:1.7;color:#7b6c5b}
.version-badge{padding:8rpx 16rpx;border-radius:999rpx;background:rgba(139,106,69,.12);font-size:22rpx;color:#8b6a45;font-weight:600;white-space:nowrap}
.highlight-grid{margin-top:22rpx;display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}
.highlight-item{padding:18rpx 16rpx;border-radius:20rpx;background:#fff8ef;border:1rpx solid rgba(139,106,69,.08)}
.highlight-label{display:block;font-size:20rpx;color:#9a8d7e;margin-bottom:8rpx}
.highlight-value{display:block;font-size:24rpx;line-height:1.5;color:#4e4337;font-weight:600}
.section-title{display:block;font-size:30rpx;font-weight:600;color:#2d2418;margin-bottom:18rpx}
.paragraph-group{display:flex;flex-direction:column;gap:14rpx}
.paragraph{font-size:24rpx;line-height:1.9;color:#4e4337}
.bullet-list{display:flex;flex-direction:column;gap:14rpx}
.bullet-item{display:flex;align-items:flex-start;gap:12rpx}
.bullet-dot{font-size:24rpx;color:#8b6a45;line-height:1.8}
.bullet-text{flex:1;font-size:24rpx;line-height:1.8;color:#4e4337}
.info-row{display:flex;justify-content:space-between;gap:16rpx;padding:12rpx 0;border-bottom:1rpx solid #f1eadf}
.info-row:last-child{border-bottom:none}
.label{font-size:24rpx;color:#8a7b69}.value{font-size:24rpx;color:#2d2418;font-weight:600;text-align:right}
.footer-copy{padding:12rpx 0 20rpx;text-align:center;font-size:22rpx;color:#9a8d7e}
@media (max-width: 375px){.highlight-grid{grid-template-columns:1fr}.hero-top{flex-direction:column}.version-badge{align-self:flex-start}}
